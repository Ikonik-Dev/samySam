# Copiez ce fichier en .env.local et remplacez les valeurs par vos secrets locaux.
# Ne jamais committer .env.local dans le dépôt Git.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=your_app_secret_here
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://root:your_db_password@127.0.0.1:3306/samySam?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> stripe/stripe-php ###
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
###< stripe/stripe-php ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###
