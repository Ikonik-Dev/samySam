{% extends 'base.html.twig' %}

{% block title %}Mon Panier
{% endblock %}

{% block body %}
	<h2 class="mb-4">Mon Panier</h2>

	{% if items is empty %}

		<div class="alert alert-info">Votre panier est vide.</div>
		<a href="{{ path('app_shop_index') }}" class="btn btn-primary">
			Continuer mes achats
		</a>

	{% else %}

		<table class="table table-bordered align-middle">
			<thead class="table-dark">
				<tr>
					<th>Produit</th>
					<th>Prix unitaire</th>
					<th>Quantité</th>
					<th>total</th>
					<th>Action</th>
				</tr>
			</thead>
			<tbody>
				{% for item in items %}
					<tr>
						<td>{{ item.productName }}</td>
						<td>{{ (item.price / 100)|number_format(2, ',', ' ') }}
							€</td>
						<td>{{ item.quantity }}</td>
						<td>{{ (item.total / 100)|number_format(2, ',', ' ') }}
							€</td>
						<td>
							<form method="post" action="{{ path('app_cart_remove', {id: item.productId}) }}">							<input type="hidden" name="_token" value="{{ csrf_token('cart_remove') }}">								<button class="btn btn-sm btn-danger">Supprimer</button>
							</form>
						</td>
					</tr>
				{% endfor %}
			</tbody>
			<tfoot>
				<tr class="fw-bold fs-5">
					<td colspan="3" class="text-end">Total :</td>
					<td>{{ (total / 100)|number_format(2, ',', ' ') }}
						€</td>
					<td>
						<form method="post" action="{{ path('app_cart_clear') }}">
							<input type="hidden" name="_token" value="{{ csrf_token('cart_clear') }}">
							<button class="btn btn-sm btn-warning">Vider</button>
						</form>
					</td>
				</tr>
			</tfoot>
		</table>

		<div class="d-flex justify-content-between mt-3">
			<form method="post" action="{{ path('app_order_checkout') }}">
				<input type="hidden" name="_token" value="{{ csrf_token('checkout') }}">
				<button type="submit" class="btn btn-success btn-lg">
					💳 Payer
					{{ (total / 100)|number_format(2, ',', ' ') }}
					€
				</button>
			</form>

		</div>

	{% endif %}
{% endblock %}
