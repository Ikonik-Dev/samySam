<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>
			{% block title %}Shop
			{% endblock %}
		</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
	</head>
	<body>

		<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
			<div class="container">
				<a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('app_shop_index') }}">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 100 100" role="img" aria-hidden="true" focusable="false">
						<title>Shop</title>
						<polygon points="0,0 100,0 50,86.6" fill="#fff" />
					</svg>
					<span class="text-white ms-2">Shop</span>
				</a>

				<div class="navbar-nav ms-auto d-flex flex-row gap-3">
					{% if app.user %}
						{% if is_granted('ROLE_ADMIN') %}
							<a class="nav-link text-white" href="{{ path('admin') }}">Admin</a>
						{% endif %}
						<a class="nav-link text-white" href="{{ path('app_cart_index') }}">🛒 Panier</a>
						<a class="nav-link text-white" href="{{ path('app_order_index') }}">📦 Mes commandes</a>
						<a class="nav-link text-white" href="{{ path('app_logout') }}">Déconnexion</a>
					{% else %}
						<a class="nav-link text-white" href="{{ path('app_register') }}">Inscription</a>
						<a class="nav-link text-white" href="{{ path('app_login') }}">Connexion</a>
					{% endif %}
				</div>
			</div>
		</nav>

		<div class="container">
			{% for type, messages in app.flashes %}
				{% for message in messages %}
					<div class="alert alert-{{ type }} alert-dismissible fade show">
						{{ message }}
						<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
					</div>
				{% endfor %}
			{% endfor %}

			{% block body %}{% endblock %}
		</div>

		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
	</body>
</html>
