{% extends 'base.html.twig' %}

{% block title %}Commande annulée{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="text-center">
        <h1 class="text-warning">❌ Commande annulée</h1>

        <p class="mt-3 lead">La commande <strong>{{ order.reference }}</strong> a été annulée.</p>

        <div class="card mx-auto mt-3" style="max-width:720px;">
            <div class="card-body">
                <p class="mb-1">Aucun montant n'a été débité. Si vous pensez qu'il y a un problème, vérifiez votre relevé bancaire ou contactez le support.</p>

                {% if order.orderItems is not empty %}
                    <div class="table-responsive mt-3">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Article</th>
                                    <th class="text-center">Qté</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in order.orderItems %}
                                    <tr>
                                        <td>{{ item.productName }}</td>
                                        <td class="text-center">{{ item.quantity }}</td>
                                        <td class="text-end">{{ (item.totalCents / 100)|number_format(2, ',', ' ') }} €</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}

                <div class="mt-3">
                    <a href="{{ path('app_cart_index') }}" class="btn btn-outline-secondary me-2">Retour au panier</a>
                    <a href="{{ path('app_shop_index') }}" class="btn btn-primary">Retour à la boutique</a>
                </div>
                <p class="text-muted small mt-3 mb-0">Besoin d'aide ? <a href="mailto:support@yourshop.example">support@yourshop.example</a></p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
