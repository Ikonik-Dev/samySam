{% extends 'base.html.twig' %}

{% block title %}Commande confirmée{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="text-center">
        <h1 class="text-success">✅ Merci — commande bien reçue</h1>

        <p class="lead">Ta commande a été enregistrée et le paiement est confirmé.</p>

        <div class="card mx-auto mt-4" style="max-width: 720px;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h5 class="card-title mb-0">Récapitulatif de la commande</h5>
                        <small class="text-muted">Référence : <strong>{{ order.reference }}</strong></small>
                    </div>
                    <div class="text-end">
                        <div><strong>{{ (order.totalAmount / 100)|number_format(2, ',', ' ') }} €</strong></div>
                        <div class="mt-1"><span class="badge bg-success">Payée</span></div>
                    </div>
                </div>

                {% if order.orderItems is not empty %}
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Article</th>
                                    <th class="text-center">Prix unité</th>
                                    <th class="text-center">Qté</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in order.orderItems %}
                                    <tr>
                                        <td>{{ item.productName }}</td>
                                        <td class="text-center">{{ (item.unitPriceCents / 100)|number_format(2, ',', ' ') }} €</td>
                                        <td class="text-center">{{ item.quantity }}</td>
                                        <td class="text-end">{{ (item.totalCents / 100)|number_format(2, ',', ' ') }} €</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <p class="mb-0">(Aucun article enregistré pour cette commande.)</p>
                {% endif %}

                <p class="text-muted small mt-3 mb-0">Date : {{ order.createdAt|date('d/m/Y à H:i') }}</p>
            </div>
        </div>

        <div class="mt-4">
            <a href="{{ path('app_shop_index') }}" class="btn btn-primary me-2">Continuer mes achats</a>
            <a href="{{ path('app_cart_index') }}" class="btn btn-outline-secondary">Voir mon panier</a>
        </div>

        <div class="mt-3 text-muted small">
            <p class="mb-1">Un reçu vous a été envoyé par email si l'adresse était renseignée.</p>
            <p class="mb-0">Besoin d'aide ? Contactez <a href="mailto:support@yourshop.example">notre support</a>.</p>
        </div>
    </div>
</div>
{% endblock %}
